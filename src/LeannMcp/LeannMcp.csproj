<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>leann-dotnet</AssemblyName>

    <!-- NuGet / dotnet tool packaging -->
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>leann-mcp</ToolCommandName>
    <PackageId>LeannMcp</PackageId>
    <Description>LEANN MCP Server — semantic code search powered by ONNX Runtime. Provides MCP tools for RAG-based code retrieval with GPU-accelerated embedding (DirectML on Windows, CoreML on macOS).</Description>
    <PackageTags>mcp;semantic-search;onnx;rag;code-search;directml;coreml</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/d-german/leann-dotnet</PackageProjectUrl>
    <PackageReadmeFile>README.md</PackageReadmeFile>

    <!-- Self-contained publish settings (only affect `dotnet publish`, not `dotnet pack`) -->
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CSharpFunctionalExtensions" Version="3.7.0" />
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.5" />
    <PackageReference Include="Microsoft.ML.Tokenizers" Version="2.0.0" />
    <PackageReference Include="ModelContextProtocol" Version="1.1.0" />

    <!--
      Cross-platform GPU acceleration:
      - DirectML provides Windows-only native DLLs with GPU (DirectX 12) support.
      - Base OnnxRuntime provides macOS (CoreML) and Linux (CPU) native DLLs.
      - Both packages depend on OnnxRuntime.Managed for the C# API.
      - ExcludeAssets="native" on the base package prevents its Windows DLLs
        from overwriting DirectML's GPU-enabled versions.
    -->
    <PackageReference Include="Microsoft.ML.OnnxRuntime.DirectML" Version="1.24.3" />
    <PackageReference Include="Microsoft.ML.OnnxRuntime" Version="1.24.3" ExcludeAssets="native" />
  </ItemGroup>

  <!--
    Manually include non-Windows native libraries from the base OnnxRuntime package.
    ExcludeAssets="native" above prevents ALL native assets from base, so we selectively
    re-include macOS and Linux native libraries here.
  -->
  <ItemGroup>
    <None Include="$(NuGetPackageRoot)microsoft.ml.onnxruntime\1.24.3\runtimes\osx-arm64\native\*"
          Pack="true" PackagePath="runtimes\osx-arm64\native" Link="runtimes\osx-arm64\native\%(Filename)%(Extension)"
          CopyToOutputDirectory="PreserveNewest" />
    <None Include="$(NuGetPackageRoot)microsoft.ml.onnxruntime\1.24.3\runtimes\linux-x64\native\*"
          Pack="true" PackagePath="runtimes\linux-x64\native" Link="runtimes\linux-x64\native\%(Filename)%(Extension)"
          CopyToOutputDirectory="PreserveNewest" />
    <None Include="$(NuGetPackageRoot)microsoft.ml.onnxruntime\1.24.3\runtimes\linux-arm64\native\*"
          Pack="true" PackagePath="runtimes\linux-arm64\native" Link="runtimes\linux-arm64\native\%(Filename)%(Extension)"
          CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
