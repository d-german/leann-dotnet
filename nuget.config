<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="ProGet-NuGet" value="https://proget.onbase.net/nuget/NuGet/v3/index.json" />
  </packageSources>

  <!--
    Authentication for ProGet (if required):

    Per machine (developers):
      dotnet nuget update source ProGet-NuGet -u YOUR_USER -p YOUR_API_KEY

    CI/CD (GitHub Actions):
      Set PROGET_API_KEY secret, then:
      dotnet nuget push pkg.nupkg -s https://proget.onbase.net/nuget/NuGet/v3/index.json -k $PROGET_API_KEY
  -->
</configuration>